---
// 友情链接页面
import BaseLayout from '../layouts/BaseLayout.astro';

// 读取友链数据
interface Link {
  name: string;
  url: string;
  description?: string;
}

import linksData from '../data/links.json';

const links: Link[] = linksData || [];
---
<BaseLayout title="友情链接 — My Blog" description="友情链接">
  <h1>友情链接</h1>
  <p style="margin-bottom: var(--spacing-lg); color: var(--color-text-muted);">
    朋友们的有趣网站
  </p>
  {links.length > 0 ? (
    <ul class="links-list">
      {links.map((link: Link) => (
        <li class="link-item">
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            <span>{link.name}</span>
            {link.description && <span class="link-desc">{link.description}</span>}
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: var(--color-text-muted);">
      还没有友链。登录 <a href="/admin/">管理后台</a> 添加吧。
    </p>
  )}
</BaseLayout>
