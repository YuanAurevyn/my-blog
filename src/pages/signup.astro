---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="注册 — My Blog">
  <h1>创建管理员账号</h1>
  <p style="margin-bottom: var(--spacing-lg); color: var(--color-text-muted);">
    点击下方按钮注册管理员账号。
  </p>
  <p id="status" style="margin-bottom: 1rem; font-size: 0.9rem;">准备中...</p>
  <button id="signup-btn" style="
    padding: 12px 32px;
    background: #ccc;
    color: #fff;
    border: none;
    font-size: 1rem;
    cursor: not-allowed;
    font-family: inherit;
  " disabled>请稍候...</button>
</BaseLayout>

<script>
(function() {
  var s = document.getElementById('status');
  var b = document.getElementById('signup-btn');

  function ok() {
    s.textContent = '已就绪';
    s.style.color = '#333';
    b.textContent = '注册账号（Sign up）';
    b.style.background = '#000';
    b.style.cursor = 'pointer';
    b.disabled = false;
    b.onclick = function() {
      window.netlifyIdentity.open('signup');
    };
  }

  function fail(msg) {
    s.textContent = msg;
    s.style.color = 'red';
  }

  // Already loaded by BaseLayout?
  if (window.netlifyIdentity) return ok();

  // Wait for it
  var tries = 0;
  var timer = setInterval(function() {
    tries++;
    if (window.netlifyIdentity) {
      clearInterval(timer);
      ok();
    } else if (tries > 50) {
      clearInterval(timer);
      fail('加载超时，请刷新页面再试。若多次失败可能是网络问题。');
    }
    if (tries === 5) { s.textContent = '仍在加载...'; }
    if (tries === 15) { s.textContent = '网络较慢，请耐心等待...'; }
  }, 200);
})();
</script>
