---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="注册管理员 — My Blog">
  <h1>注册管理员账号</h1>
  <p style="margin-bottom: var(--spacing-md); color: var(--color-text-muted);">
    填写邮箱和密码创建账号。
  </p>

  <form id="form" style="max-width: 400px;">
    <div style="margin-bottom: 1rem;">
      <label style="display: block; margin-bottom: 4px; font-size: 0.9rem;">邮箱</label>
      <input type="email" id="email" required style="
        width: 100%; padding: 10px 12px; border: 1px solid #ddd;
        font-size: 1rem; font-family: inherit; box-sizing: border-box;
      " placeholder="your@email.com">
    </div>
    <div style="margin-bottom: 1.5rem;">
      <label style="display: block; margin-bottom: 4px; font-size: 0.9rem;">密码</label>
      <input type="password" id="password" required minlength="6" style="
        width: 100%; padding: 10px 12px; border: 1px solid #ddd;
        font-size: 1rem; font-family: inherit; box-sizing: border-box;
      " placeholder="至少 6 位">
    </div>
    <button type="submit" style="
      width: 100%; padding: 12px; background: #000; color: #fff;
      border: none; font-size: 1rem; cursor: pointer; font-family: inherit;
    ">注册</button>
  </form>

  <p id="msg" style="margin-top: 1rem;"></p>
  <p style="margin-top: 2rem; font-size: 0.85rem; color: #aaa;">
    已有账号？<a href="/admin/" style="color: #555;">去登录 →</a>
  </p>
</BaseLayout>

<script>
  document.getElementById('form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var msg = document.getElementById('msg');
    var email = document.getElementById('email').value;
    var password = document.getElementById('password').value;

    msg.style.color = '#888';
    msg.textContent = '正在注册...';

    try {
      var res = await fetch('/.netlify/identity/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, password: password })
      });
      var data = await res.json();
      if (res.ok) {
        msg.style.color = 'green';
        msg.textContent = '注册成功！跳转到管理后台...';
        setTimeout(function() {
          location.href = '/admin/';
        }, 1500);
      } else {
        msg.style.color = 'red';
        msg.textContent = '注册失败：' + (data.msg || data.error || JSON.stringify(data));
      }
    } catch (err) {
      msg.style.color = 'red';
      msg.textContent = '请求失败：' + err.message + ' （可能是网络问题，请稍后重试）';
    }
  });
</script>
