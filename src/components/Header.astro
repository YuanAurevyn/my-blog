---
// Header.astro — 顶部导航
const currentPath = Astro.url?.pathname || '/';

function isActive(path: string) {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
}
---
<header class="site-header">
  <div class="container">
    <a href="/" class="site-title">My Blog</a>
    <nav>
      <ul class="site-nav">
        <li><a href="/articles/" class:list={[{ active: isActive('/articles') }]}>文章</a></li>
        <li><a href="/works/" class:list={[{ active: isActive('/works') }]}>作品</a></li>
        <li><a href="/about/" class:list={[{ active: isActive('/about') }]}>关于</a></li>
        <li><a href="/links/" class:list={[{ active: isActive('/links') }]}>友链</a></li>
      </ul>
    </nav>
  </div>
</header>
